{
  "name": "cts-antifraud",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/web",
    "packages/extension"
  ],
  "scripts": {
    "dev:server": "npm run dev -w packages/server",
    "dev:web": "npm run dev -w packages/web",
    "build": "npm run build -w packages/shared && npm run build -w packages/server && npm run build -w packages/web && npm run build -w packages/extension",
    "build:shared": "npm run build -w packages/shared",
    "build:server": "npm run build -w packages/server",
    "build:web": "npm run build -w packages/web",
    "build:extension": "npm run build -w packages/extension",
    "migrate": "npm run migrate -w packages/server",
    "migrate:rollback": "npm run migrate:rollback -w packages/server",
    "migrate:make": "npm run migrate:make -w packages/server",
    "seed": "npm run seed -w packages/server",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'packages/*/src/**/*.{ts,tsx}' --fix",
    "typecheck": "tsc --build packages/shared packages/server packages/extension packages/web",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx,json}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx,json}'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
