# ─── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/cts_antifraud
API_KEY=your-shared-secret-key

# ─── Optional ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ─── AI/ML Keys (optional — required for AI analysis endpoints) ─────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Telegram Bot (optional) ─────────────────────────────────────────────────
# Получить токен через @BotFather, chat_id через @userinfobot
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=
DASHBOARD_URL=http://localhost:5173

# ─── Testing ─────────────────────────────────────────────────────────────────
# TEST_DATABASE_URL=postgresql://test:test@localhost:5432/cts_test
